# DB
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=handy_v2

# JWT
SECRET_KEY=your-secret-key
ALGORITHM=HS256

# ENV
ENV=development   # production으로 바꾸면 secure 쿠키 활성화

# 소셜 로그인
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8000/api/auth/apple/callback

# SMS (Solapi)
SMS_CLIENT_ID=
SMS_CLIENT_SECRET=
SMS_SENDER=

# Firebase
FIREBASE_KEY_PATH=./firebase-service-account.json

# 사업자등록번호 공공 API
VITE_BUSINESS_API_KEY=

# 프론트엔드 URL (소셜 로그인 리다이렉트용)
VITE_API_URL=http://localhost:5173
